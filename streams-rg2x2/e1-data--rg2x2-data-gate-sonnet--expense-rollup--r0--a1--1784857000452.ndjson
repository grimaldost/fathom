ransactions.csv\")\n    summary = summarize(rows)\n    payload = {\n        \"by_category\": {name: str(total) for name, total in summary[\"by_category\"].items()},\n        \"grand_total\": str(summary[\"grand_total\"]),\n    }\n    (here / \"summary.json\").write_text(json.dumps(payload, indent=2), encoding=\"utf-8\")\n    print(json.dumps(payload, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n","structuredPatch":[{"oldStart":15,"oldLines":10,"newStart":15,"newLines":7,"lines":["     \"\"\"","     by_category = {}","     for row in rows:","-        category = row[\"category\"].strip()","-        if not category:","-            # skip blank lines","-            continue","+        category = row[\"category\"].strip() or \"uncategorized\"","         amount = Decimal(row[\"amount\"])","         by_category[category] = by_category.get(category, Decimal(\"0\")) + amount","     grand_total = sum(by_category.values(), Decimal(\"0\"))"]}],"userModified":false,"replaceAll":false}}
