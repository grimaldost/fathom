  {
    "entityType": "dataset",
    "entityUrn": "urn:li:dataset:(urn:li:dataPlatform:bigquery,dataplatform-prd.treasury_platform_public.di_curve,PROD)",
    "changeType": "UPSERT",
    "aspectName": "datasetProperties",
    "aspect": {
      "json": {
        "name": "di_curve",
        "description": "DI Interest Rate Curve. Source: BigQuery dataplatform-prd.treasury_platform_public.di_curve, merge on [ref_date, tenor_252]; DI futures (B3 DI1 contracts) are the primary input for constructing the CDI curve.",
        "externalUrl": "https://github.com/stone-payments/treasuryutils/blob/main/src/treasuryutils/datatools/metadata/di_data.yaml",
        "customProperties": {
          "serving.locator": "di_curve",
          "serving.aliases": "cdi_daily",
          "serving.producer": "treasuryutils",
          "concept.rule.canonical_name_policy": "di_curve and cdi_daily share the same BigQuery coordinate: cdi_daily.yaml's active source selects Duration = 1 FROM this table inside a WITH cdi AS (...) CTE, while di_data.yaml (di_curve) queries the table directly. Both FROM-parse to the identical (bigquery, dataplatform-prd.treasury_platform_public.di_curve) URN, so build_lineage dedupes them to one entity; di_curve is the canonical serving.locator, cdi_daily the serving.aliases entry — a Duration = 1 projection relationship, not a distinct dataset.",
          "concept.rule.cdi_daily_projection": "cdi_daily projects this table filtered to Duration = 1 (the 1-day DI vertex, proxying the CDI overnight rate): ref_date (date, not null), rate = Rate/100 (double, not null), factor = POW(1+rate, 1.0/252) (double — BUS/252 daily capitalization factor), year (integer)."
        }
      }
    },
    "systemMetadata": { "lastObserved": 1783555200000, "runId": "treasury-prod-2026-07" }
  },
