          "concept.rule.refresh_policy": "evidenced: refresh_policy if_stale max_age_seconds=604800",
          "concept.rule.calendar_construction": "date spine 2001-01-01 to 2099-12-31; weekend = dayofweek in {0,6}; workday = not weekend and not holiday; workday_num is a running business-day index; last_workday/next_workday and their indices are also computed"
        }
      }
    },
