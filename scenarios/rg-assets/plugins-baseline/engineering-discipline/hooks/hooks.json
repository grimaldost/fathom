{
  "description": "Mechanical enforcement: ruff-format at end of turn across every edited file (PostToolBatch, non-blocking; requires CLI >= 2.1.218); steer Bash/PowerShell toward uv inside uv projects (PreToolUse, CLAUDE_ALLOW_PIP=1 to override); and an inert-by-default data pre-shipping-checklist nudge (Stop, enable with DATAENG_CHECKLIST_NUDGE=1).",
  "hooks": {
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "--", "python", "${CLAUDE_PLUGIN_ROOT}/hooks/ruff_format.py"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "--", "python", "${CLAUDE_PLUGIN_ROOT}/hooks/uv_enforce.py"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "--", "python", "${CLAUDE_PLUGIN_ROOT}/hooks/stop_nudge.py"]
          }
        ]
      }
    ]
  }
}
