{
  "description": "Optional hooks, all shipped wired but INERT. SessionStart: (1) live toolkit inventory - silent unless TOOLKIT_AWARENESS_INJECT=1; (2) control-anchor re-injection on compact/resume (compaction-survival) - silent unless SESSION_WORKFLOW_ANCHOR_HOOKS=1. PostToolUse/Stop: (3) skill-exercise ledger - silent unless SESSION_WORKFLOW_EXERCISE_LEDGER=1; (4) feedback-debt Stop nudge - silent unless SESSION_WORKFLOW_FEEDBACK_NUDGE=1. See the plugin README to enable any.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/toolkit-awareness/scripts/scan_toolkit.py",
              "--session-start"
            ]
          }
        ]
      },
      {
        "matcher": "compact|resume|clear|startup",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/compaction-survival/scripts/anchor_inject.py"
            ]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Skill$|^mcp__plugin_.*",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/tool-feedback/scripts/exercise_ledger.py",
              "--record"
            ],
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/tool-feedback/scripts/exercise_ledger.py",
              "--stop-nudge"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
