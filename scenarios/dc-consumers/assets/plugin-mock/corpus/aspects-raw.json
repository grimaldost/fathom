  {
    "entityType": "dataset",
    "entityUrn": "urn:li:dataset:(urn:li:dataPlatform:bigquery,dataplatform-prd.raw_acquiring.transactions,PROD)",
    "changeType": "UPSERT",
    "aspectName": "datasetProperties",
    "aspect": {
      "json": {
        "name": "raw_transactions",
        "description": "Hourly append-only ingestion of captured card transactions from core_acquiring. Monetary amounts are integer BRL centavos at this layer.",
        "customProperties": {
          "serving.locator": "raw_transactions",
          "serving.producer": "dataplatform",
          "concept.owner.team": "data-platform-eng",
          "concept.rule.unit_convention": "Monetary amounts in raw_acquiring are integer BRL CENTAVOS (1/100 BRL); the single conversion to decimal BRL happens at stg_transactions (amount_brl = amount_centavos / 100). Never divide again downstream.",
          "concept.rule.ingestion": "Append-only hourly CDC loads; duplicate events possible — dedup by event_id happens at stg_transactions, not here."
        }
      }
    },
    "systemMetadata": {
      "lastObserved": 1783641600000,
      "runId": "mock-payments-2026-07"
    }
  },
