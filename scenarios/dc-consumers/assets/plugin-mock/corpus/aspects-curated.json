[
  {
    "entityType": "dataset",
    "entityUrn": "urn:li:dataset:(urn:li:dataPlatform:bigquery,dataplatform-prd.curated.stg_transactions,PROD)",
    "changeType": "UPSERT",
    "aspectName": "datasetProperties",
    "aspect": {
      "json": {
        "name": "stg_transactions",
        "description": "Deduplicated, BRL-decimal view of captured transactions. This is where centavos become BRL and where the America/Sao_Paulo business date is derived.",
        "customProperties": {
          "serving.locator": "stg_transactions",
          "serving.producer": "dataplatform",
          "concept.owner.team": "data-platform-eng",
          "concept.rule.unit_convention": "amount_brl = raw amount_centavos / 100, converted HERE and only here; all curated/mart layers are decimal BRL.",
          "concept.rule.timezone": "event_time_utc is UTC; event_date_brt is the business date in America/Sao_Paulo derived from it. Daily reports group by event_date_brt, never by DATE(event_time_utc).",
          "concept.rule.dedup": "One row per event_id; latest status wins."
        }
      }
    },
    "systemMetadata": {
      "lastObserved": 1783641600000,
      "runId": "mock-payments-2026-07"
    }
  },
