{
  "description": "Dispatch-protocol injection, all inert by default. (1) SessionStart full-protocol inject — silent unless HUMBLEPOWERS_DISPATCH_INJECT=1. (2) Per-prompt tiered inject + lexical router (UserPromptSubmit) — silent unless HUMBLEPOWERS_DISPATCH_PROMPT_INJECT=1; when on, it subsumes and silences (1). (3) Cadence-state reset on compact|clear so the first post-reset prompt re-escalates to the full protocol. See the plugin README to enable.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/choosing-tools/scripts/inject_dispatch.py",
              "--session-start"
            ],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/choosing-tools/scripts/inject_dispatch.py",
              "--reset-state"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "--",
              "python",
              "${CLAUDE_PLUGIN_ROOT}/skills/choosing-tools/scripts/inject_dispatch.py",
              "--prompt-submit"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
